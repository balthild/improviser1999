{
	"includes": [
		"package.json",
		"tsconfig.json",
		"dprint.json",
		"wrangler.jsonc",
		"*.config.{js,ts}",
		"scripts/*.ts",
		"src/**/*.{svelte,js,ts,css,html,svg}",
		".vscode/*.json",
	],
	"excludes": [
		"**/node_modules",
		"**/*-lock.json",
		"**/favicon.svg",
	],
	"useTabs": true,
	"indentWidth": 2,
	"lineWidth": 100,
	"oxc": {
		"quoteStyle": "single",
		"quoteProperties": "consistent",
		"experimentalSortImports": {
			"groups": [
				["style", "side_effect_style"],
				["builtin"],
				["external"],
				["svelte"],
				["internal", "subpath"],
				["parent", "sibling", "index"],
				["unknown"],
			],
			"internalPattern": ["~/", "@/", "$lib/"],
			"customGroups": [
				{
					"groupName": "svelte",
					"elementNamePattern": ["$app/**", "$env/**", "$service-worker"],
				},
			],
		},
	},
	"markup": {
		"styleIndent": true,
		"scriptIndent": true,
		"scriptFormatter": "biome",
		"associations": ["*.{html,svelte,svg}"],
		"html.void.selfClosing": true,
		"component.selfClosing": true,
	},
	"malva": {
		"quotes": "preferSingle",
	},
	"json": {
		"trailingCommas": "jsonc",
		"jsonTrailingCommaFiles": [
			"tsconfig.json",
			"dprint.json",
			"wrangler.jsonc",
			".vscode/extensions.json",
			".vscode/settings.json",
		],
	},
	"plugins": [
		"https://plugins.dprint.dev/oxc-0.14.0.wasm",
		"https://plugins.dprint.dev/json-0.21.3.wasm",
		"https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.0.wasm",
		"https://plugins.dprint.dev/g-plane/malva-v0.15.2.wasm",
	],
}
