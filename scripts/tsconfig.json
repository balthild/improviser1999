{
	"compilerOptions": {
		"lib": ["esnext"],
		"types": ["node"],
		"module": "esnext",
		"target": "esnext",
		"moduleDetection": "force",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
	},
}
